<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.aloha.minihome.mapper.GuestbookMapper">

    <resultMap id="guestbookMap" type="Guestbook">
        <id     property="id"        column="id" />
        <result property="ownerId"   column="owner_id" />
        <result property="nickname"  column="nickname" />
        <result property="password"  column="password" />
        <result property="content"   column="content" />
        <result property="createdAt" column="created_at" />
    </resultMap>

    <!-- 방명록 목록 조회 (홈 주인 기준, 최신순, 페이징) -->
    <select id="selectByOwnerId" resultMap="guestbookMap">
        SELECT * FROM guestbook
        WHERE owner_id = #{ownerId}
        ORDER BY created_at DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <!-- 방명록 단건 조회 -->
    <select id="selectById" resultMap="guestbookMap">
        SELECT * FROM guestbook WHERE id = #{id}
    </select>

    <!-- 방명록 작성 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO guestbook (owner_id, nickname, password, content)
        VALUES (#{ownerId}, #{nickname}, #{password}, #{content})
    </insert>

    <!-- 방명록 삭제 (비밀번호 검증) -->
    <delete id="delete">
        DELETE FROM guestbook WHERE id = #{id} AND password = #{password}
    </delete>

</mapper>