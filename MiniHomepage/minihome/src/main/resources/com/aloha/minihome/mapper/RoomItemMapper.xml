<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.aloha.minihome.mapper.RoomItemMapper">

    <resultMap id="roomItemMap" type="RoomItem">
        <id     property="id"        column="id" />
        <result property="userId"    column="user_id" />
        <result property="itemType"  column="item_type" />
        <result property="positionX" column="position_x" />
        <result property="positionY" column="position_y" />
        <result property="zIndex"    column="z_index" />
        <result property="createdAt" column="created_at" />
    </resultMap>

    <!-- 룸 아이템 목록 조회 -->
    <select id="selectByUserId" resultMap="roomItemMap">
        SELECT * FROM room_items
        WHERE user_id = #{userId}
        ORDER BY z_index ASC
    </select>

    <!-- 룸 아이템 단건 조회 -->
    <select id="selectById" resultMap="roomItemMap">
        SELECT * FROM room_items WHERE id = #{id}
    </select>

    <!-- 아이템 배치 추가 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO room_items (user_id, item_type, position_x, position_y, z_index)
        VALUES (#{userId}, #{itemType}, #{positionX}, #{positionY}, #{zIndex})
    </insert>

    <!-- 아이템 위치 수정 -->
    <update id="update">
        UPDATE room_items
        SET position_x = #{positionX},
            position_y = #{positionY},
            z_index    = #{zIndex}
        WHERE id = #{id}
    </update>

    <!-- 아이템 단건 삭제 -->
    <delete id="delete">
        DELETE FROM room_items WHERE id = #{id}
    </delete>

    <!-- 유저의 모든 아이템 삭제 -->
    <delete id="deleteByUserId">
        DELETE FROM room_items WHERE user_id = #{userId}
    </delete>

</mapper>
