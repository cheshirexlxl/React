<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.aloha.minihome.mapper.VisitorCountMapper">

    <resultMap id="visitorCountMap" type="VisitorCount">
        <id     property="id"        column="id" />
        <result property="userId"    column="user_id" />
        <result property="visitDate" column="visit_date" />
        <result property="count"     column="count" />
    </resultMap>

    <!-- 특정 날짜 방문자 수 조회 -->
    <select id="selectByUserIdAndDate" resultMap="visitorCountMap">
        SELECT * FROM visitor_count
        WHERE user_id = #{userId}
          AND visit_date = #{visitDate}
    </select>

    <!-- 총 방문자 수 조회 -->
    <select id="selectSumByUserId" resultType="int">
        SELECT COALESCE(SUM(count), 0)
        FROM visitor_count
        WHERE user_id = #{userId}
    </select>

    <!-- 오늘 방문자 수 최초 삽입 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO visitor_count (user_id, visit_date, count)
        VALUES (#{userId}, #{visitDate}, 1)
    </insert>

    <!-- 오늘 방문자 수 증가 -->
    <update id="increment">
        UPDATE visitor_count
        SET count = count + 1
        WHERE user_id = #{userId}
          AND visit_date = #{visitDate}
    </update>

</mapper>